APP_BASE_URL=http://localhost:8080
API_BASE_URL=http://localhost:8080
UI_BASE_URL=http://localhost:8080

TEST_USERNAME=test.user
TEST_PASSWORD=ChangeMe123!
INVALID_TEST_PASSWORD=WrongPassword123!

REQUEST_TIMEOUT=30
SKIP_ON_UNREACHABLE=true
UI_HEADLESS=true
UI_SLOW_MO=0
UI_EXPECT_TIMEOUT=10000

API_AUTH_ENDPOINT=/api/auth/login
API_TICKETS_ENDPOINT=/api/tickets
AUTH_HEADER_PREFIX=Bearer

LOGIN_PATH=/login
DASHBOARD_PATH=/dashboard
CREATE_TICKET_PATH=/tickets/new

UI_USERNAME_SELECTOR=input[name='username']
UI_PASSWORD_SELECTOR=input[name='password']
UI_LOGIN_BUTTON_SELECTOR=button[type='submit']
UI_LOGIN_ERROR_SELECTOR=.alert-danger
UI_DASHBOARD_MARKER_SELECTOR=main
UI_TICKET_TITLE_SELECTOR=input[name='title']
UI_TICKET_DESCRIPTION_SELECTOR=textarea[name='description']
UI_TICKET_SUBMIT_SELECTOR=button[type='submit']
UI_TICKET_SUCCESS_SELECTOR=.alert-success
UI_LOGOUT_MENU_SELECTOR=[data-testid='user-menu']
UI_LOGOUT_BUTTON_SELECTOR=text=Logout
